                <div class="form-group">
                    <label>Uri ng transaksyon o serbisyo</label>
                    <div class="radio-group">
                        <label class="radio-option">
                            <input type="radio" name="uri_transaksyon" value="Facilitation of the Control of Documented Information" required>
                            <span class="radio-label">Facilitation of the Control of Documented Information</span>
                        </label>
                        <label class="radio-option">
                            <input type="radio" name="uri_transaksyon" value="Others">
                            <span class="radio-label">Others</span>
                        </label>
                    </div>
                </div>

                <div class="form-group" id="othersGroup" style="display:none;">
                    <label for="others_specify">Please specify</label>
                    <input type="text" id="others_specify" name="others_specify" placeholder="Specify other transaction/service">
                </div>

                <!-- Citizen's Charter Section -->
                <div class="section-title"><i class="fas fa-landmark"></i> Citizen's Charter (CC)</div>
                
                <div class="sqd-instruction">
                    PANUTO: Lagyan ng tsek (✔) ang iyong sagot sa mga sumusunod na katanungan tungkol sa Citizen's Charter (CC). 
                    Ito ay isang opisyal na dokumento na naglalaman ng mga serbisyo sa isang ahensya/opisina ng gobyerno, 
                    makikita rito ang mga kailangan na dokumento, kaukulang bayarin at pagkabuuang oras ng proseso.
                </div>

                <!-- CC1 -->
                <div class="sqd-item">
                    <div class="sqd-label"><strong>CC1</strong> — Alin sa mga sumusunod ang naglalarawan sa iyong kaalaman sa CC?</div>
                    <div class="sqd-options" style="flex-direction: column;">
                        <label class="check-option">
                            <input type="radio" name="cc1" value="1" required>
                            <span class="check-label">Alam ko ang CC at nakita ko ito sa napuntahang opisina</span>
                        </label>
                        <label class="check-option">
                            <input type="radio" name="cc1" value="2">
                            <span class="check-label">Alam ko ang CC pero hindi ko ito nakita sa napuntahang opisina</span>
                        </label>
                        <label class="check-option">
                            <input type="radio" name="cc1" value="3">
                            <span class="check-label">Nalaman ko ang CC nang makita ko ito sa napuntahang opisina</span>
                        </label>
                        <label class="check-option">
                            <input type="radio" name="cc1" value="4">
                            <span class="check-label">Hindi ko alam kung ano ang CC at wala akong nakita sa napuntahang opisina</span>
                        </label>
                    </div>
                </div>

                <!-- CC2 -->
                <div class="sqd-item" id="cc2Container">
                    <div class="sqd-label"><strong>CC2</strong> — Kung alam ang CC (nag-tsek sa opsyon 1-3 sa CC1), masasabi mo ba na ang CC nang napuntahang opisina ay...?</div>
                    <div class="sqd-options" style="flex-direction: column;">
                        <label class="check-option"><input type="radio" name="cc2" value="1"><span class="check-label">Madaling makita</span></label>
                        <label class="check-option"><input type="radio" name="cc2" value="2"><span class="check-label">Medyo madaling makita</span></label>
                        <label class="check-option"><input type="radio" name="cc2" value="3"><span class="check-label">Mahirap makita</span></label>
                        <label class="check-option"><input type="radio" name="cc2" value="4"><span class="check-label">Hindi makita</span></label>
                        <label class="check-option"><input type="radio" name="cc2" value="N/A"><span class="check-label">N/A</span></label>
                    </div>
                </div>

                <!-- CC3 -->
                <div class="sqd-item" id="cc3Container">
                    <div class="sqd-label"><strong>CC3</strong> — Kung alam ang CC (nag-tsek sa opsyon 1-3 sa CC1), gaano nakatulong ang CC sa transaksyon mo?</div>
                    <div class="sqd-options" style="flex-direction: column;">
                        <label class="check-option"><input type="radio" name="cc3" value="1"><span class="check-label">Sobrang nakatulong</span></label>
                        <label class="check-option"><input type="radio" name="cc3" value="2"><span class="check-label">Nakatulong naman</span></label>
                        <label class="check-option"><input type="radio" name="cc3" value="3"><span class="check-label">Hindi nakatulong</span></label>
                        <label class="check-option"><input type="radio" name="cc3" value="N/A"><span class="check-label">N/A</span></label>
                    </div>
                </div>

                <!-- SQD Section -->
                <div class="section-title"><i class="fas fa-chart-bar"></i> Service Quality Dimensions (SQD 0-8)</div>
                
                <div class="sqd-instruction">
                    PANUTO: Para sa SQD 0-8, lagyan ng tsek (✔) ang hanay na pinakaangkop sa iyong sagot.
                </div>

                <% 
                const sqdItems = [
                    { id: 'sqd0', label: 'SQD0. Nasiyahan ako sa serbisyo na aking natanggap sa napuntahan na tanggapan.' },
                    { id: 'sqd1', label: 'SQD1. Makatawiran ang oras na aking ginugol para sa pagproseso ng aking transaksyon.' },
                    { id: 'sqd2', label: 'SQD2. Ang opisina ay sumusunod sa mga kinakailangang dokumento at mga hakbang batay sa impormasyong ibinigay.' },
                    { id: 'sqd3', label: 'SQD3. Ang mga hakbang sa pagproseso, kasama na ang pagbayad ay madali at simple lamang.' },
                    { id: 'sqd4', label: 'SQD4. Mabilis at madali akong nakahanap ng impormasyon tungkol sa aking transaksyon mula sa opisina o sa website nito.' },
                    { id: 'sqd5', label: 'SQD5. Nagbayad ako ng makatwirang halaga para sa aking transaksyon. (Kung ang serbisyo ay ibinigay ng libre, maglagay ng tsek sa hanay ng N/A).' },
                    { id: 'sqd6', label: 'SQD6. Pakiramdam ko ay patas ang opisina sa lahat, o "walang palakasan".' },
                    { id: 'sqd7', label: 'SQD7. Magalang akong tinrato ng mga tauhan, at (kung sakali ako ay humingi ng tulong) alam ko na sila ay handang tumulong sa akin.' },
                    { id: 'sqd8', label: 'SQD8. Nakuha ko ang kinakailangan ko mula sa tanggapan ng gobyerno, kung tinanggihan man, ito ay sapat na ipinaliwanag sa akin.' }
                ];
                
                const ratingLabels = [
                    { value: '1', emoji: '😡', text: 'Lubos na hindi sumasang-ayon' },
                    { value: '2', emoji: '🙁', text: 'Hindi sumasang-ayon' },
                    { value: '3', emoji: '😐', text: 'Walang kinikilingan' },
                    { value: '4', emoji: '🙂', text: 'Sumasang-ayon' },
                    { value: '5', emoji: '😍', text: 'Lubos na sumasang-ayon' },
                    { value: 'N/A', emoji: '🚫', text: 'N/A' }
                ];
                %>

                <% sqdItems.forEach(function(item) { %>
                <div class="sqd-item">
                    <div class="sqd-label"><strong><%= item.label.split('.')[0] %></strong>.<%= item.label.split('.').slice(1).join('.') %></div>
                    <div class="emoji-grid">
                        <% ratingLabels.forEach(function(rating) { %>
                        <label class="emoji-card">
                            <input type="radio" name="<%= item.id %>" value="<%= rating.value %>" required>
                            <div class="emoji-card-content">
                                <span class="emoji-face"><%= rating.emoji %></span>
                                <span class="emoji-label"><%= rating.text %></span>
                            </div>
                        </label>
                        <% }); %>
                    </div>
                </div>
                <% }); %>

                <!-- Suggestions & Email -->
                <div class="section-title"><i class="fas fa-comment-dots"></i> Karagdagang Feedback</div>

                <div class="form-group full-width">
                    <label for="suggestions">Mga suhestiyon kung paano pa mapapabuti ang aming mga serbisyo (opsyonal)</label>
                    <textarea id="suggestions" name="suggestions" placeholder="Isulat dito ang iyong suhestiyon..." rows="4"></textarea>
                </div>

                <div class="form-group full-width">
                    <label for="email">Email address (opsyonal)</label>
                    <input type="email" id="email" name="email" placeholder="iyong.email@example.com">
                </div>

                <!-- Submit -->
                <div class="submit-section">
                    <button type="submit" class="btn-submit" id="submitBtn">
                        <i class="fas fa-paper-plane"></i> Isumite ang Feedback
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<script>
    // Auto-fill today's date
    document.getElementById('petsa').value = new Date().toISOString().split('T')[0];

    // Show/hide "Others" input
    document.querySelectorAll('input[name="uri_transaksyon"]').forEach(r => {
        r.addEventListener('change', function() {
            document.getElementById('othersGroup').style.display = this.value === 'Others' ? 'block' : 'none';
        });
    });

    // CC1 logic: auto-select N/A for CC2 and CC3 when option 4 is selected
    document.querySelectorAll('input[name="cc1"]').forEach(r => {
        r.addEventListener('change', function() {
            if (this.value === '4') {
                document.querySelector('input[name="cc2"][value="N/A"]').checked = true;
                document.querySelector('input[name="cc3"][value="N/A"]').checked = true;
            }
        });
    });

    // Update office code in header
    document.getElementById('tanggapan').addEventListener('change', function() {
        const selectedOption = this.options[this.selectedIndex];
        const code = selectedOption.getAttribute('data-code');
        if (code) {
            document.getElementById('headerOfficeCode').textContent = code;
        }
    });

    // Auto-select office from URL query parameter (e.g. ?office=OQA)
    const urlParams = new URLSearchParams(window.location.search);
    const officeParam = urlParams.get('office');
    if (officeParam) {
        const selectEl = document.getElementById('tanggapan');
        const paramLower = officeParam.toLowerCase().trim();
        for (let i = 0; i < selectEl.options.length; i++) {
            const opt = selectEl.options[i];
            const optVal = opt.value.toLowerCase().trim();
            const optCode = (opt.getAttribute('data-code') || '').toLowerCase().trim();
            if (optCode === paramLower || optVal === paramLower) {
                selectEl.selectedIndex = i;
                // Trigger change event to update the header code
                selectEl.dispatchEvent(new Event('change'));
                break;
            }
        }
    }

    // Form submission with loading state
    document.getElementById('feedbackForm').addEventListener('submit', function() {
        const btn = document.getElementById('submitBtn');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner"></span> Nagsusumite...';
    });
</script>

