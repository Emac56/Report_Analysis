<%- include('partials/header', { pageTitle: 'Customer Feedback Form - PSAU QMS' }) %>

<div class="form-page">
    <div class="form-container">
        <form id="feedbackForm" action="/submit-feedback" method="POST" class="form-card">
            
            <!-- Header -->
            <div class="form-header">
                <div class="control-no">Quality Management System Unit &nbsp;&nbsp;&nbsp; Control No.: QMS-CFF-2026 &nbsp;-&nbsp; <span id="headerOfficeCode">OQA</span></div>
                <h1>CUSTOMER FEEDBACK FORM</h1>
                <div class="subtitle">Pampanga State Agricultural University</div>
            </div>

            <!-- Introduction -->
            <div class="form-intro">
                <strong style="color:var(--psau-gold);">TULUNGAN MO KAMI MAS MAPABUTI ANG AMING MGA PROSESO AT SERBISYO!</strong><br><br>
                Salamat sa pagbisita sa Pampanga State Agricultural University (PSAU) isang malaking kasiyahan para amin na lagging maibigay sa inyo ang 
                pinakamahusay na kalidad ng serbisyo. Ang Client Satisfaction Measurement (CSM) ay naglalayong masubaybayan ang karanasan ng taumbabayan
                hingil sainyong naging karanasan sa kakatapos lamang na transaksyon, upang mas mapabuti at lalong mapahusay ang aming sebisyo publiko.
                Ang personal ng impormasyon sa iyong ibabahagi ay mananatiling kumpidensyal. Maari ring piliin na hindi sagutan ang sarbey na ito.
            </div>

            <div class="form-body">
                <!-- Personal Information -->
                <div class="section-title"><i class="fas fa-user"></i> Impormasyon ng Kliyente</div>
                
                <div class="form-row">
                    <div class="form-group">
                        <label for="pangalan">Pangalan</label>
                        <input type="text" id="pangalan" name="pangalan" placeholder="Iyong pangalan" required>
                    </div>
                    <div class="form-group">
                        <label for="telepono">Telepono</label>
                        <input type="text" id="telepono" name="telepono" placeholder="Numero ng telepono">
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Uri ng Kliyente</label>
                        <div class="radio-group">
                            <label class="radio-option">
                                <input type="radio" name="uri_kliyente" value="Mamamayan" required>
                                <span class="radio-label">Mamamayan</span>
                            </label>
                            <label class="radio-option">
                                <input type="radio" name="uri_kliyente" value="Negosyo">
                                <span class="radio-label">Negosyo</span>
                            </label>
                            <label class="radio-option">
                                <input type="radio" name="uri_kliyente" value="Gobyerno">
                                <span class="radio-label">Gobyerno (Empleyado o Ahensya)</span>
                            </label>
                        </div>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="petsa">Petsa</label>
                        <input type="date" id="petsa" name="petsa" required>
                    </div>
                    <div class="form-group">
                        <label>Kasarian</label>
                        <div class="radio-group">
                            <label class="radio-option">
                                <input type="radio" name="kasarian" value="Lalaki" required>
                                <span class="radio-label">Lalaki</span>
                            </label>
                            <label class="radio-option">
                                <input type="radio" name="kasarian" value="Babae">
                                <span class="radio-label">Babae</span>
                            </label>
                        </div>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="edad">Edad</label>
                        <input type="number" id="edad" name="edad" placeholder="Edad" min="1" max="120" required>
                    </div>
                    <div class="form-group">
                        <label for="rehiyon">Rehiyon</label>
                        <input type="text" id="rehiyon" name="rehiyon" placeholder="Rehiyon">
                    </div>
                </div>

