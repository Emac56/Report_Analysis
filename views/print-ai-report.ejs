<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Feedback Analysis Report - PSAU</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', sans-serif;
            background: #fff;
            color: #1e2233;
            font-size: 14px;
            line-height: 1.6;
            padding: 2.5rem;
        }
        .report-container { max-width: 800px; margin: 0 auto; }
        .report-header {
            text-align: center;
            padding-bottom: 1.5rem;
            border-bottom: 3px solid #1B5E20;
            margin-bottom: 2rem;
        }
        .report-header h1 {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 1.8rem;
            font-weight: 800;
            color: #1B5E20;
            margin-bottom: 0.25rem;
        }
        .report-header .subtitle {
            color: #4a5568;
            font-size: 0.9rem;
        }
        .report-header .meta {
            margin-top: 0.75rem;
            display: flex;
            justify-content: center;
            gap: 1.5rem;
            flex-wrap: wrap;
            font-size: 0.8rem;
            color: #718096;
        }
        .report-content {
            font-size: 0.95rem;
            color: #1e2233;
            margin-bottom: 3rem;
        }
        /* Style standard blocks generated by EJS */
        .report-content strong {
            color: #1B5E20;
            font-weight: 700;
        }
        .report-content br {
            margin-bottom: 0.5rem;
            content: "";
            display: block;
        }
        .report-footer {
            text-align: center;
            padding-top: 1.5rem;
            border-top: 1px solid #e2e8f0;
            color: #718096;
            font-size: 0.75rem;
        }
        .print-btn-bar {
            text-align: center;
            margin-bottom: 2rem;
        }
        .print-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.65rem 1.5rem;
            background: #1B5E20;
            color: #fff;
            border: none;
            border-radius: 8px;
            font-weight: 700;
            font-size: 0.85rem;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
        }
        .print-btn:hover { background: #2E7D32; }
        @media print {
            @page {
                margin: 0;
            }
            body {
                margin: 1.6cm;
                padding: 0;
            }
            .print-btn-bar { display: none; }
        }
    </style>
</head>
<body>
    <div class="report-container">
        <div class="print-btn-bar">
            <button class="print-btn" onclick="window.print()">Print / Save as PDF</button>
            <button class="print-btn" style="background:#4a5568;margin-left:0.75rem;" onclick="window.close()">Close</button>
        </div>

        <div class="report-header">
            <h1>AI Feedback Analysis Summary</h1>
            <p class="subtitle">Pampanga State Agricultural University — Quality Management System</p>
            <div class="meta">
                <span><strong>Office:</strong> <%= officeName %></span>
                <% if (dateFrom) { %><span><strong>From:</strong> <%= dateFrom %></span><% } %>
                <% if (dateTo) { %><span><strong>To:</strong> <%= dateTo %></span><% } %>
                <span><strong>Generated:</strong> <%= generatedAt %></span>
            </div>
        </div>

        <div class="report-content">
            <% if (aiAnalysisCleaned) { %>
                <%- aiAnalysisCleaned %>
            <% } else { %>
                <p style="color:#718096; text-align:center; padding:2rem; font-style:italic;">No AI report analysis content found. Please generate the analysis on the dashboard first.</p>
            <% } %>
        </div>

        <div class="report-footer">
            <p>Pampanga State Agricultural University — Quality Management System &copy; <%= new Date().getFullYear() %></p>
            <p style="margin-top:0.25rem;">This report summary was generated by PSAU Feedback Analytics AI.</p>
        </div>
    </div>
</body>
</html>
