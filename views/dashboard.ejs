            {name:"Project Development, Management and Monitoring Unit",code:"PMU"}
        ]}
    ];

    const qrSelect = document.getElementById('qrOfficeSelect');
    offices.forEach(g => {
        const og = document.createElement('optgroup');
        og.label = g.category;
        g.items.forEach(i => { const o = document.createElement('option'); o.value = i.code; o.textContent = `${i.name} (${i.code})`; og.appendChild(o); });
        qrSelect.appendChild(og);
    });

    const qrContainer = document.getElementById('qrCodeContainer');
    const qrDisplaySide = document.getElementById('qrDisplaySide');
    const downloadBtn = document.getElementById('downloadQRBtn');

    qrSelect.addEventListener('change', function() {
        const code = this.value;
        const targetUrl = `${window.location.origin}/?office=${code}`;
        qrContainer.innerHTML = '';
        document.getElementById('qrUrlText').textContent = targetUrl;
        document.getElementById('qrDetails').style.display = 'block';
        downloadBtn.style.display = 'inline-flex';
        qrDisplaySide.classList.add('has-qr');
        if (typeof QRCode !== 'undefined') {
            new QRCode(qrContainer, { text: targetUrl, width: 200, height: 200, colorDark: "#1B5E20", colorLight: "#ffffff", correctLevel: QRCode.CorrectLevel.H });
        } else {
            const img = document.createElement('img');
            img.src = `https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=${encodeURIComponent(targetUrl)}&color=1B5E20`;
            img.style.cssText = 'width:200px;height:200px;';
            qrContainer.appendChild(img);
        }
    });

    downloadBtn.addEventListener('click', function() {
        const name = `PSAU_QR_${qrSelect.options[qrSelect.selectedIndex].textContent.replace(/\s+/g,'_').replace(/[()]/g,'')}.png`;
        const canvas = qrContainer.querySelector('canvas');
        if (canvas) { const a = document.createElement('a'); a.download = name; a.href = canvas.toDataURL("image/png"); a.click(); }
    });

    // ========== FILTER & REPORT FUNCTIONS ==========
    function applyFilters() {
        const params = new URLSearchParams();
        const office = document.getElementById('officeFilter').value;
        if (office !== 'all') params.set('office', office);
        const dateFrom = document.getElementById('dateFrom').value;
        const dateTo = document.getElementById('dateTo').value;
        if (dateFrom) params.set('dateFrom', dateFrom);
        if (dateTo) params.set('dateTo', dateTo);
        window.location.href = '/admin/dashboard?' + params.toString();
    }

    function generateReport() {
        const params = new URLSearchParams();
        const office = document.getElementById('officeFilter').value;
        if (office !== 'all') params.set('office', office);
        const dateFrom = document.getElementById('dateFrom').value;
        const dateTo = document.getElementById('dateTo').value;
        if (dateFrom) params.set('dateFrom', dateFrom);
        if (dateTo) params.set('dateTo', dateTo);
        window.open('/admin/report?' + params.toString(), '_blank');
    }

    // Allow Enter key on date inputs to trigger filter
    document.querySelectorAll('.filter-date').forEach(el => {
        el.addEventListener('keydown', e => { if (e.key === 'Enter') applyFilters(); });
    });

    // ========== CHARTS ==========
    const sqdAverages = <%- JSON.stringify(chartData.sqdAverages) %>;
    const sentimentCounts = <%- JSON.stringify(chartData.sentimentCounts) %>;
    const ccCounts = <%- JSON.stringify(chartData.ccCounts) %>;
    const genderCounts = <%- JSON.stringify(chartData.genderCounts) %>;

    Chart.defaults.color = '#9ea4b8';
    Chart.defaults.borderColor = 'rgba(42, 47, 66, 0.5)';
    Chart.defaults.font.family = 'Inter';

    new Chart(document.getElementById('sqdChart'), {
        type: 'bar',
        data: {
            labels: ['SQD0','SQD1','SQD2','SQD3','SQD4','SQD5','SQD6','SQD7','SQD8'],
            datasets: [{ label: 'Average Rating', data: sqdAverages,
                backgroundColor: ['rgba(92,107,192,0.7)','rgba(126,87,194,0.7)','rgba(38,166,154,0.7)','rgba(102,187,106,0.7)','rgba(255,167,38,0.7)','rgba(236,64,122,0.7)','rgba(66,165,245,0.7)','rgba(171,71,188,0.7)','rgba(255,112,67,0.7)'],
                borderRadius: 8, borderSkipped: false }]
        },
        options: { responsive: true, scales: { y: { beginAtZero: true, max: 5, grid: { color: 'rgba(42,47,66,0.3)' } }, x: { grid: { display: false } } }, plugins: { legend: { display: false } } }
    });

    new Chart(document.getElementById('sentimentChart'), {
        type: 'doughnut',
        data: { labels: ['Positive','Neutral','Negative','Mixed'], datasets: [{ data: [sentimentCounts.positive, sentimentCounts.neutral, sentimentCounts.negative, sentimentCounts.mixed], backgroundColor: ['rgba(102,187,106,0.8)','rgba(158,164,184,0.8)','rgba(239,83,80,0.8)','rgba(255,167,38,0.8)'], borderWidth: 0, hoverOffset: 10 }] },
        options: { responsive: true, cutout: '55%', plugins: { legend: { position: 'bottom', labels: { padding: 16 } } } }
    });

    new Chart(document.getElementById('ccChart'), {
        type: 'doughnut',
        data: { labels: ['1. Alam + Nakita','2. Alam pero hindi nakita','3. Nalaman nang makita','4. Hindi alam'], datasets: [{ data: [ccCounts.cc1_1, ccCounts.cc1_2, ccCounts.cc1_3, ccCounts.cc1_4], backgroundColor: ['rgba(102,187,106,0.8)','rgba(92,107,192,0.8)','rgba(255,167,38,0.8)','rgba(239,83,80,0.8)'], borderWidth: 0, hoverOffset: 10 }] },
        options: { responsive: true, cutout: '55%', plugins: { legend: { position: 'bottom', labels: { padding: 12, font: { size: 11 } } } } }
    });

    new Chart(document.getElementById('genderChart'), {
        type: 'doughnut',
        data: { labels: ['Lalaki','Babae'], datasets: [{ data: [genderCounts.lalaki, genderCounts.babae], backgroundColor: ['rgba(92,107,192,0.8)','rgba(236,64,122,0.8)'], borderWidth: 0, hoverOffset: 10 }] },
        options: { responsive: true, cutout: '55%', plugins: { legend: { position: 'bottom', labels: { padding: 16 } } } }
    });

    // ========== DETAILED VIEW MODAL LOGIC ==========
    const modal = document.getElementById('feedbackModal');
    const closeBtn = document.querySelector('.close-modal');
    const feedbacksData = <%- JSON.stringify(feedbacks) %>;

    document.querySelectorAll('.feedback-row').forEach(row => {
        row.addEventListener('click', function() {
            const idx = parseInt(this.dataset.index);
            const fb = feedbacksData[idx];
            if (!fb) return;

            // Populate demographics
            document.getElementById('m-pangalan').textContent = fb.pangalan || 'N/A';
            document.getElementById('m-uri-kliyente').textContent = fb.uri_kliyente || 'N/A';
            document.getElementById('m-edad').textContent = fb.edad || 'N/A';
            document.getElementById('m-kasarian').textContent = fb.kasarian || 'N/A';
            document.getElementById('m-rehiyon').textContent = fb.rehiyon || 'N/A';
            document.getElementById('m-telepono').textContent = fb.telepono || 'N/A';
            document.getElementById('m-email').textContent = fb.email || 'N/A';

            // Populate service details
            document.getElementById('m-tanggapan').textContent = fb.tanggapan || 'N/A';
            
            let petsaText = 'N/A';
            if (fb.petsa) {
                petsaText = fb.petsa;
            } else if (fb.submittedAt) {
                try {
                    petsaText = new Date(fb.submittedAt).toISOString().split('T')[0];
                } catch (e) {}
            }
            document.getElementById('m-petsa').textContent = petsaText;
            document.getElementById('m-uri-transaksyon').textContent = fb.uri_transaksyon || 'N/A';

            // Populate rating & comments
            document.getElementById('m-avgsqd').textContent = (fb.avgSQD || '0.00') + '/5.00';
            document.getElementById('m-suggestions').textContent = fb.suggestions || 'Walang nakasulat na suhestiyon.';

            const sentiment = fb.sentiment || 'Neutral';
            const badgeEl = document.getElementById('m-sentiment');
            badgeEl.className = 'badge ' + sentiment.toLowerCase();
            badgeEl.textContent = sentiment;

            for (let i = 0; i <= 8; i++) {
                document.getElementById(`m-sqd${i}`).textContent = fb[`sqd${i}`] || '0';
            }

            modal.style.display = 'block';
        });
    });

    closeBtn.addEventListener('click', () => {
        modal.style.display = 'none';
    });

    window.addEventListener('click', (e) => {
        if (e.target === modal) {
            modal.style.display = 'none';
        }
    });

    // ========== MANUAL AI REPORT GENERATION ==========
    function printAIReport() {
        const params = new URLSearchParams();
        const office = document.getElementById('officeFilter').value;
        if (office !== 'all') params.set('office', office);
        const dateFrom = document.getElementById('dateFrom').value;
        const dateTo = document.getElementById('dateTo').value;
        if (dateFrom) params.set('dateFrom', dateFrom);
        if (dateTo) params.set('dateTo', dateTo);
        window.open('/admin/print-ai-report?' + params.toString(), '_blank');
    }

    async function triggerAIAnalysis(forceRefresh) {
        const container = document.getElementById('aiAnalysisContainer');
        const refreshBtn = document.getElementById('btnRefreshAI');
        const printBtn = document.getElementById('btnPrintAI');
        
        // Show loading state in container
        container.innerHTML = `
            <div style="text-align: center; padding: 3.5rem 1rem;">
                <div class="spinner" style="margin: 0 auto 1.25rem auto;"></div>
                <h4 style="color: var(--text-primary); margin-bottom: 0.5rem; font-weight: 700;">Analyzing Feedback Data...</h4>
                <p style="color: var(--text-muted); font-size: 0.85rem; max-width: 350px; margin: 0 auto; line-height: 1.5;">
                    Pollinations AI (GPT-4o) is parsing client responses, calculating performance highlights, and drafting recommendations. This may take a few seconds.
                </p>
            </div>
        `;

        if (refreshBtn) refreshBtn.style.display = 'none';
        if (printBtn) printBtn.style.display = 'none';

        try {
            const office = document.getElementById('officeFilter').value;
            const dateFrom = document.getElementById('dateFrom').value;
            const dateTo = document.getElementById('dateTo').value;

            const params = new URLSearchParams({ office, dateFrom, dateTo });
            if (forceRefresh) {
                params.append('refresh', 'true');
            }

            const response = await fetch('/admin/generate-ai-report?' + params.toString());
            const result = await response.json();

            if (result.success) {
                container.innerHTML = `<div class="ai-analysis-content">${result.aiAnalysis}</div>`;
                if (refreshBtn) refreshBtn.style.display = 'flex';
                if (printBtn) printBtn.style.display = 'flex';
            } else {
                container.innerHTML = `
                    <div style="text-align: center; padding: 2.5rem 1rem; border: 1px dashed rgba(244,67,54,0.3); border-radius: 8px; background: rgba(244,67,54,0.02);">
                        <i class="fas fa-exclamation-triangle" style="font-size: 2.5rem; color: #f44336; margin-bottom: 1rem;"></i>
                        <h4 style="color: #f44336; margin-bottom: 0.5rem; font-weight: 700;">Failed to Generate Report</h4>
                        <p style="color: var(--text-muted); font-size: 0.85rem; max-width: 450px; margin: 0 auto 1.5rem auto; line-height: 1.5;">
                            ${result.error || 'Unknown error occurred.'}
                        </p>
                        <button class="btn-submit" onclick="triggerAIAnalysis(${forceRefresh})" style="margin: 0 auto; display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.6rem 1.2rem; background: #f44336; border: none; color: white; border-radius: 6px; cursor: pointer;">
                            <i class="fas fa-redo"></i> Try Again
                        </button>
                    </div>
                `;
            }
        } catch (err) {
            console.error('AJAX AI Generation error:', err);
            container.innerHTML = `
                <div style="text-align: center; padding: 2.5rem 1rem; border: 1px dashed rgba(244,67,54,0.3); border-radius: 8px; background: rgba(244,67,54,0.02);">
                    <i class="fas fa-exclamation-triangle" style="font-size: 2.5rem; color: #f44336; margin-bottom: 1rem;"></i>
                    <h4 style="color: #f44336; margin-bottom: 0.5rem; font-weight: 700;">Network Error</h4>
                    <p style="color: var(--text-muted); font-size: 0.85rem; max-width: 450px; margin: 0 auto 1.5rem auto; line-height: 1.5;">
                        Could not connect to the server. Please check your connection and try again.
                    </p>
                    <button class="btn-submit" onclick="triggerAIAnalysis(${forceRefresh})" style="margin: 0 auto; display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.6rem 1.2rem; background: #f44336; border: none; color: white; border-radius: 6px; cursor: pointer;">
                        <i class="fas fa-redo"></i> Try Again
                    </button>
                </div>
            `;
        }
    }
</script>

<%- include('partials/footer') %>