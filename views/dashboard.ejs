            {name:"Department of Fisheries",code:"DOF"},{name:"Department of Food Technology",code:"DFT"},
            {name:"College of Forestry and Agroforestry",code:"CFA"},{name:"Department of Agroforestry",code:"DAF"},
            {name:"Department of Forestry",code:"DFR"},{name:"College of Arts and Sciences",code:"CAS"},
            {name:"Department of Biology",code:"DOB"},{name:"Department of Development Communication",code:"DDC"},
            {name:"Department of English",code:"DOE"},{name:"Department of Mathematics",code:"DOM"},
            {name:"Department of Social Sciences",code:"DSS"},{name:"College of Education",code:"COE"},
            {name:"Department of Elementary Education",code:"DEE"},{name:"Department of Physical Education",code:"DPE"},
            {name:"Department of Professional and General Education",code:"DPG"},{name:"Department of Secondary Education",code:"DSE"},
            {name:"Department of Technology and Livelihood Education",code:"DTL"},{name:"College of Engineering and Computer Studies",code:"CEC"},
            {name:"Department of Agricultural and Biosystems Engineering",code:"DAB"},{name:"Department of Civil Engineering",code:"DCI"},
            {name:"Department of Computer Engineering",code:"DCP"},{name:"Department of Computer Studies",code:"DCS"},
            {name:"Department of Geodetic Engineering",code:"DGE"},{name:"College of Business, Economics and Entrepreneurship",code:"CBE"},
            {name:"Department of Agricultural Business",code:"DAG"},{name:"Department of Agricultural Economics",code:"DAE"},
            {name:"Department of Entrepreneurship",code:"DEN"},{name:"Department of Hospitality Management",code:"DHM"},
            {name:"College of Veterinary Medicine",code:"CVM"},{name:"Department of Veterinary Basic Sciences",code:"DVB"},
            {name:"Graduate School",code:"GRS"},{name:"Office of Admissions and Registration",code:"OAR"},
            {name:"Registration Unit",code:"RGU"},{name:"Office of Alumni Relations and Placement",code:"OAP"},
            {name:"Office of Cultural and Performing Arts",code:"OCP"},{name:"Office of Guidance and Testing",code:"OGT"},
            {name:"Office of Library Services and Museum",code:"OLM"},{name:"Office of Sports Development",code:"OSD"},
            {name:"Office of Student Affairs and Services",code:"OSS"},{name:"National Service Training Program Unit",code:"NSU"},
            {name:"Special Academic Programs and Services Unit",code:"SAU"}
        ]},
        { category: "Administration and Finance Cluster", items: [
            {name:"Office of the Vice President for Administration and Finance",code:"VAF"},{name:"Office of Administrative Services",code:"OAS"},
            {name:"Cash Unit",code:"CSU"},{name:"Human Resource Management Unit",code:"HRU"},{name:"Procurement Unit",code:"PRU"},
            {name:"Records Unit",code:"RCU"},{name:"Supply and Property Management Unit",code:"SPU"},
            {name:"Office of Financial Services",code:"OFS"},{name:"Accounting Unit",code:"ACU"},{name:"Budget Unit",code:"BDU"},
            {name:"Office of General and Auxiliary Services",code:"OGA"},{name:"Faculty, Staff and Student Housing Unit",code:"FSU"},
            {name:"Ground and Physical Plant Improvement Unit",code:"GPU"},{name:"Health Unit",code:"HEU"},
