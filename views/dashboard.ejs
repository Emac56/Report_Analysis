                    <option value="College of Engineering and Computer Studies" <%= selectedOffice === 'College of Engineering and Computer Studies' ? 'selected' : '' %>>College of Engineering and Computer Studies (CEC)</option>
                    <option value="Department of Agricultural and Biosystems Engineering" <%= selectedOffice === 'Department of Agricultural and Biosystems Engineering' ? 'selected' : '' %>>Department of Agricultural and Biosystems Engineering (DAB)</option>
                    <option value="Department of Civil Engineering" <%= selectedOffice === 'Department of Civil Engineering' ? 'selected' : '' %>>Department of Civil Engineering (DCI)</option>
                    <option value="Department of Computer Engineering" <%= selectedOffice === 'Department of Computer Engineering' ? 'selected' : '' %>>Department of Computer Engineering (DCP)</option>
                    <option value="Department of Computer Studies" <%= selectedOffice === 'Department of Computer Studies' ? 'selected' : '' %>>Department of Computer Studies (DCS)</option>
                    <option value="Department of Geodetic Engineering" <%= selectedOffice === 'Department of Geodetic Engineering' ? 'selected' : '' %>>Department of Geodetic Engineering (DGE)</option>
                    <option value="College of Business, Economics and Entrepreneurship" <%= selectedOffice === 'College of Business, Economics and Entrepreneurship' ? 'selected' : '' %>>College of Business, Economics and Entrepreneurship (CBE)</option>
                    <option value="Department of Agricultural Business" <%= selectedOffice === 'Department of Agricultural Business' ? 'selected' : '' %>>Department of Agricultural Business (DAG)</option>
