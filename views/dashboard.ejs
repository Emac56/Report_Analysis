<%- include('partials/header', { pageTitle: 'Dashboard - PSAU Feedback Analytics', useCharts: true }) %>

<style>
@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}
.spinner {
    display: inline-block;
    width: 2rem;
    height: 2rem;
    vertical-align: text-bottom;
    border: 3px solid rgba(27, 94, 32, 0.1);
    border-top-color: var(--psau-green);
    border-radius: 50%;
    animation: spin .75s linear infinite;
}
.btn-refresh-ai-inline:hover {
    background: rgba(255, 255, 255, 0.15) !important;
    border-color: var(--psau-green) !important;
}
</style>

<div class="dashboard-page">
    <nav class="dash-nav">
        <a href="/admin/dashboard" class="brand">
            <span>PSAU Feedback Analytics</span>
        </a>
        <div class="nav-actions">
            <span class="admin-label"><i class="fas fa-user-shield"></i> Admin</span>
            <a href="/admin/dashboard" class="btn-nav-refresh" title="Refresh data"><i class="fas fa-sync-alt"></i></a>
            <a href="/admin/logout" class="btn-logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
        </div>
    </nav>

    <div class="dash-content">
        <div class="dash-header">
            <div class="dash-header-left">
                <h1><i class="fas fa-chart-bar" style="color:var(--psau-green);"></i> Feedback Analytics Dashboard</h1>
                <p>AI-powered analysis of customer feedback responses</p>
            </div>
            <div class="dash-header-right">
                <span class="dash-date-badge"><i class="fas fa-calendar-alt"></i> <%= new Date().toLocaleDateString('en-PH', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
            </div>
        </div>

