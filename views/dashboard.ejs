                    <option value="Security Unit" <%= selectedOffice === 'Security Unit' ? 'selected' : '' %>>Security Unit (SEU)</option>
                    <option value="Office of the Board Secretary" <%= selectedOffice === 'Office of the Board Secretary' ? 'selected' : '' %>>Office of the Board Secretary (OBS)</option>
                    <option value="Office of Gender and Development" <%= selectedOffice === 'Office of Gender and Development' ? 'selected' : '' %>>Office of Gender and Development (OGD)</option>
                    <option value="Office of Institutional Quality Assurance" <%= selectedOffice === 'Office of Institutional Quality Assurance' ? 'selected' : '' %>>Office of Institutional Quality Assurance (OQA)</option>
