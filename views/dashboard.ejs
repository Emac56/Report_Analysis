                    <option value="Department of English" <%= selectedOffice === 'Department of English' ? 'selected' : '' %>>Department of English (DOE)</option>
                    <option value="Department of Mathematics" <%= selectedOffice === 'Department of Mathematics' ? 'selected' : '' %>>Department of Mathematics (DOM)</option>
                    <option value="Department of Social Sciences" <%= selectedOffice === 'Department of Social Sciences' ? 'selected' : '' %>>Department of Social Sciences (DSS)</option>
                    <option value="College of Education" <%= selectedOffice === 'College of Education' ? 'selected' : '' %>>College of Education (COE)</option>
