<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script>
    // ========== QR CODE GENERATOR ==========
    const offices = [
        { category: "President Cluster", items: [
            {name:"Office of the President",code:"OPR"},{name:"Internal Audit Unit",code:"IAU"},{name:"Legal Unit",code:"LEU"},
            {name:"Security Unit",code:"SEU"},{name:"Office of the Board Secretary",code:"OBS"},{name:"Office of Gender and Development",code:"OGD"},
