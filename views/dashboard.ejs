            <div class="chart-card">
                <h3><i class="fas fa-chart-bar"></i> SQD Average Ratings (SQD0 - SQD8)</h3>
                <canvas id="sqdChart" height="280"></canvas>
            </div>
            <div class="chart-card">
                <h3><i class="fas fa-chart-pie"></i> Sentiment Distribution</h3>
                <canvas id="sentimentChart" height="280"></canvas>
            </div>
            <div class="chart-card">
                <h3><i class="fas fa-chart-pie"></i> CC1 — Citizen's Charter Awareness</h3>
                <canvas id="ccChart" height="280"></canvas>
            </div>
            <div class="chart-card">
                <h3><i class="fas fa-venus-mars"></i> Gender Distribution</h3>
                <canvas id="genderChart" height="280"></canvas>
            </div>
        </div>        <!-- AI Analysis -->
        <div class="ai-section" style="margin-top: 2rem;">
            <div class="ai-card" style="border-left: 4px solid var(--psau-green);">
                <div class="ai-header">
                    <h3><i class="fas fa-robot"></i> AI-Powered Feedback Analysis Report</h3>
                    <div style="display:flex; align-items:center; gap:0.5rem;">
                        <% if (selectedOffice !== 'all') { %>
                        <span class="ai-badge office-badge"><%= selectedOffice %></span>
                        <% } else { %>
                        <span class="ai-badge univ-badge">UNIVERSITY-WIDE</span>
                        <% } %>
                        <span class="ai-label"><i class="fas fa-brain"></i> Pollinations AI</span>
                        <button id="btnPrintAI" class="btn-refresh-ai-inline" onclick="printAIReport()" title="Print or Save AI Analysis as PDF" style="background: var(--accent-blue); border: 1px solid var(--accent-blue); color: white; padding: 0.38rem 0.75rem; border-radius: 6px; font-size: 0.75rem; cursor: pointer; display: <%= aiAnalysis ? 'flex' : 'none' %>; align-items: center; gap: 0.35rem; transition: 0.2s;">
                            <i class="fas fa-file-pdf"></i> Save as PDF
                        </button>
                        <button id="btnRefreshAI" class="btn-refresh-ai-inline" onclick="triggerAIAnalysis(true)" title="Re-generate analysis using Pollinations AI" style="background: rgba(255,255,255,0.08); border: 1px solid var(--border-color); color: var(--text-primary); padding: 0.38rem 0.75rem; border-radius: 6px; font-size: 0.75rem; cursor: pointer; display: <%= aiAnalysis ? 'flex' : 'none' %>; align-items: center; gap: 0.35rem; transition: 0.2s;">
                            <i class="fas fa-redo"></i> Re-generate
                        </button>
                    </div>
                </div>
                
                <div id="aiAnalysisContainer">
                    <% if (aiAnalysis) { %>
                        <div class="ai-analysis-content"><%- aiAnalysis %></div>
                    <% } else { %>
                        <div class="ai-empty-state" style="text-align: center; padding: 2.5rem 1rem;">
                            <i class="fas fa-brain" style="font-size: 2.8rem; color: var(--psau-green); opacity: 0.85; margin-bottom: 1.25rem; display: block;"></i>
                            <h4 style="color: var(--text-primary); margin-bottom: 0.6rem; font-weight: 700;">AI Feedback Analysis Report</h4>
                            <p style="color: var(--text-muted); font-size: 0.85rem; max-width: 480px; margin: 0 auto 1.5rem auto; line-height: 1.5;">
                                Generate an automated quality report summarizing strengths, areas for improvement, sentiment trends, and specific action plans for the university.
                            </p>
                            <button id="btnGenerateAI" class="btn-submit" onclick="triggerAIAnalysis(false)" style="margin: 0 auto; display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.75rem 1.35rem;">
                                <i class="fas fa-magic"></i> Generate AI Analysis
                            </button>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
        <!-- K-Means Machine Learning Clustering Analysis -->
        <div class="ai-section" style="margin-top: 2rem;">
            <div class="ai-card" style="border-left: 4px solid #42a5f5;">
                <div class="ai-header">
                    <h3><i class="fas fa-project-diagram"></i> Machine Learning: K-Means Rating Pattern Clustering</h3>
                    <div style="display:flex; align-items:center; gap:0.5rem;">
                        <span class="ai-badge" style="background:rgba(66,165,245,0.15); color:#42a5f5; border: 1px solid rgba(66,165,245,0.3);">K-Means (k=3)</span>
                        <span class="ai-label"><i class="fas fa-cogs"></i> Pattern Analysis</span>
                    </div>
                </div>
                
                <p style="margin-bottom:1.5rem; color:#9ea4b8; font-size:0.9rem; line-height:1.5;">
                    This machine learning component groups the university departments/offices into clusters based on their rating patterns across all 9 Service Quality Dimensions (SQD). This identifies performance segments (Outstanding, Satisfactory, and Needs Attention) dynamically.
                </p>

                <% if (clusteredDepartments && clusteredDepartments.length > 0) { %>
                    <div style="overflow-x:auto;">
                        <table class="data-table" style="margin-top: 0.5rem;">
                            <thead>
                                <tr>
                                    <th>Rank</th>
                                    <th>Department / Office</th>
                                    <th>Avg SQD Rating</th>
                                    <th>K-Means Assigned Cluster Segment</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% clusteredDepartments.forEach(function(dept, index) { %>
                                    <tr>
                                        <td><%= index + 1 %></td>
                                        <td style="font-weight: 500;"><%= dept.name %></td>
                                        <td>
                                            <div style="display:flex; align-items:center; gap:0.5rem;">
                                                <div style="width: 80px; background: rgba(255,255,255,0.05); height: 8px; border-radius: 4px; overflow: hidden;">
                                                    <div style="width: <%= (parseFloat(dept.avgScore) / 5) * 100 %>%; background: #2e7d32; height: 100%;"></div>
                                                </div>
                                                <span><%= dept.avgScore %>/5.00</span>
                                            </div>
                                        </td>
                                        <td>
                                            <% if (dept.cluster.includes('Outstanding') || dept.cluster.includes('Excellent')) { %>
                                                <span class="badge positive" style="background: rgba(76, 175, 80, 0.15); color: #4caf50; border: 1px solid rgba(76, 175, 80, 0.3); padding: 0.35rem 0.75rem;"><%= dept.cluster %></span>
                                            <% } else if (dept.cluster.includes('Needs Attention') || dept.cluster.includes('Improvement')) { %>
                                                <span class="badge negative" style="background: rgba(244, 67, 54, 0.15); color: #f44336; border: 1px solid rgba(244, 67, 54, 0.3); padding: 0.35rem 0.75rem;"><%= dept.cluster %></span>
                                            <% } else { %>
                                                <span class="badge mixed" style="background: rgba(255, 152, 0, 0.15); color: #ff9800; border: 1px solid rgba(255, 152, 0, 0.3); padding: 0.35rem 0.75rem;"><%= dept.cluster %></span>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="ai-empty-state">
                        <i class="fas fa-network-wired"></i>
                        <p>No clustering data available.</p>
                        <p style="color:var(--text-muted); font-size:0.8rem;">Gather feedback responses from multiple departments to perform K-Means pattern classification.</p>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- QR Code Generator Card -->
        <div class="qr-card">
            <h3><i class="fas fa-qrcode"></i> Office QR Code Generator</h3>
            <p class="qr-subtitle">Select an office to generate its unique feedback form QR code. When scanned, it redirects to the form with that office pre-selected.</p>
            <div class="qr-layout">
                <div class="qr-form-side">
                    <div class="qr-select-wrap">
                        <label for="qrOfficeSelect">Select Office / Department</label>
                        <select id="qrOfficeSelect" class="qr-select"><option value="" disabled selected>Pumili ng tanggapan...</option></select>
                    </div>
                    <div id="qrDetails" class="qr-details-box">
                        <div class="qr-url-label">TARGET URL:</div>
                        <div id="qrUrlText" class="qr-url-text">http://...</div>
                    </div>
                    <button id="downloadQRBtn" class="btn-submit" style="width:100%; justify-content:center; display:none; padding:0.85rem;"><i class="fas fa-download"></i> Download QR Code Image</button>
                </div>
                <div id="qrDisplaySide" class="qr-display-side">
                    <div id="qrCodeContainer" class="qr-placeholder">
                        <i class="fas fa-qrcode"></i>
                        <span>Select an office to generate QR code</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Feedback Table -->
        <div class="table-card">
            <div class="table-header">
                <h3><i class="fas fa-table"></i> Feedback Responses (<%= feedbacks.length %>)</h3>
            </div>
            <% if (feedbacks.length > 0) { %>
            <div style="overflow-x:auto;">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Pangalan</th>
                        <th>Tanggapan</th>
                        <th>Kasarian</th>
                        <th>Edad</th>
                        <th>Avg SQD</th>
                        <th>Sentiment</th>
                        <th>Suhestiyon</th>
                        <th>Petsa</th>
                    </tr>
                </thead>
                <tbody>
                    <% feedbacks.forEach(function(fb, index) { %>
                    <tr class="feedback-row" 
                        data-index="<%= index %>"
                        style="cursor: pointer;"
                        title="Click to view full review detail"
                    >
                        <td><%= index + 1 %></td>
                        <td style="font-weight: 500;"><%= fb.pangalan || 'N/A' %></td>
                        <td style="max-width:150px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="<%= fb.tanggapan || '' %>"><%= fb.tanggapan || 'N/A' %></td>
                        <td><%= fb.kasarian || 'N/A' %></td>
                        <td><%= fb.edad || 'N/A' %></td>
                        <td style="font-weight: 700; color: var(--psau-green);"><%= fb.avgSQD || 'N/A' %></td>
                        <td>
                            <% if (fb.sentiment === 'Positive') { %>
                                <span class="badge positive">Positive</span>
                            <% } else if (fb.sentiment === 'Negative') { %>
                                <span class="badge negative">Negative</span>
                            <% } else if (fb.sentiment === 'Mixed') { %>
                                <span class="badge mixed">Mixed</span>
                            <% } else { %>
                                <span class="badge neutral">Neutral</span>
                            <% } %>
                        </td>
                        <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="<%= fb.suggestions || '' %>"><%= fb.suggestions || '—' %></td>
                        <td style="white-space:nowrap;"><%= fb.petsa || fb.submittedAt || 'N/A' %></td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
            </div>
            <% } else { %>
            <p class="table-empty">Wala pang naisumiteng feedback<%= selectedOffice !== 'all' ? ' para sa tanggapang ito' : '' %>.</p>
            <% } %>
        </div>
    </div>
</div>

<!-- Feedback Details Modal -->
