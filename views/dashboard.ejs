                    <option value="Department of Entrepreneurship" <%= selectedOffice === 'Department of Entrepreneurship' ? 'selected' : '' %>>Department of Entrepreneurship (DEN)</option>
                    <option value="Department of Hospitality Management" <%= selectedOffice === 'Department of Hospitality Management' ? 'selected' : '' %>>Department of Hospitality Management (DHM)</option>
                    <option value="College of Veterinary Medicine" <%= selectedOffice === 'College of Veterinary Medicine' ? 'selected' : '' %>>College of Veterinary Medicine (CVM)</option>
                    <option value="Department of Veterinary Basic Sciences" <%= selectedOffice === 'Department of Veterinary Basic Sciences' ? 'selected' : '' %>>Department of Veterinary Basic Sciences (DVB)</option>
                    <option value="Graduate School" <%= selectedOffice === 'Graduate School' ? 'selected' : '' %>>Graduate School (GRS)</option>
                    <option value="Office of Admissions and Registration" <%= selectedOffice === 'Office of Admissions and Registration' ? 'selected' : '' %>>Office of Admissions and Registration (OAR)</option>
                    <option value="Registration Unit" <%= selectedOffice === 'Registration Unit' ? 'selected' : '' %>>Registration Unit (RGU)</option>
                    <option value="Office of Alumni Relations and Placement" <%= selectedOffice === 'Office of Alumni Relations and Placement' ? 'selected' : '' %>>Office of Alumni Relations and Placement (OAP)</option>
                    <option value="Office of Cultural and Performing Arts" <%= selectedOffice === 'Office of Cultural and Performing Arts' ? 'selected' : '' %>>Office of Cultural and Performing Arts (OCP)</option>
                    <option value="Office of Guidance and Testing" <%= selectedOffice === 'Office of Guidance and Testing' ? 'selected' : '' %>>Office of Guidance and Testing (OGT)</option>
                    <option value="Office of Library Services and Museum" <%= selectedOffice === 'Office of Library Services and Museum' ? 'selected' : '' %>>Office of Library Services and Museum (OLM)</option>
                    <option value="Office of Sports Development" <%= selectedOffice === 'Office of Sports Development' ? 'selected' : '' %>>Office of Sports Development (OSD)</option>
                    <option value="Office of Student Affairs and Services" <%= selectedOffice === 'Office of Student Affairs and Services' ? 'selected' : '' %>>Office of Student Affairs and Services (OSS)</option>
                    <option value="National Service Training Program Unit" <%= selectedOffice === 'National Service Training Program Unit' ? 'selected' : '' %>>National Service Training Program Unit (NSU)</option>
                    <option value="Special Academic Programs and Services Unit" <%= selectedOffice === 'Special Academic Programs and Services Unit' ? 'selected' : '' %>>Special Academic Programs and Services Unit (SAU)</option>
                </optgroup>
                <optgroup label="Administration and Finance Cluster">
                    <option value="Office of the Vice President for Administration and Finance" <%= selectedOffice === 'Office of the Vice President for Administration and Finance' ? 'selected' : '' %>>Office of the Vice President for Administration and Finance (VAF)</option>
                    <option value="Office of Administrative Services" <%= selectedOffice === 'Office of Administrative Services' ? 'selected' : '' %>>Office of Administrative Services (OAS)</option>
                    <option value="Cash Unit" <%= selectedOffice === 'Cash Unit' ? 'selected' : '' %>>Cash Unit (CSU)</option>
                    <option value="Human Resource Management Unit" <%= selectedOffice === 'Human Resource Management Unit' ? 'selected' : '' %>>Human Resource Management Unit (HRU)</option>
                    <option value="Procurement Unit" <%= selectedOffice === 'Procurement Unit' ? 'selected' : '' %>>Procurement Unit (PRU)</option>
                    <option value="Records Unit" <%= selectedOffice === 'Records Unit' ? 'selected' : '' %>>Records Unit (RCU)</option>
                    <option value="Supply and Property Management Unit" <%= selectedOffice === 'Supply and Property Management Unit' ? 'selected' : '' %>>Supply and Property Management Unit (SPU)</option>
                    <option value="Office of Financial Services" <%= selectedOffice === 'Office of Financial Services' ? 'selected' : '' %>>Office of Financial Services (OFS)</option>
                    <option value="Accounting Unit" <%= selectedOffice === 'Accounting Unit' ? 'selected' : '' %>>Accounting Unit (ACU)</option>
                    <option value="Budget Unit" <%= selectedOffice === 'Budget Unit' ? 'selected' : '' %>>Budget Unit (BDU)</option>
                    <option value="Office of General and Auxiliary Services" <%= selectedOffice === 'Office of General and Auxiliary Services' ? 'selected' : '' %>>Office of General and Auxiliary Services (OGA)</option>
                    <option value="Faculty, Staff and Student Housing Unit" <%= selectedOffice === 'Faculty, Staff and Student Housing Unit' ? 'selected' : '' %>>Faculty, Staff and Student Housing Unit (FSU)</option>
                    <option value="Ground and Physical Plant Improvement Unit" <%= selectedOffice === 'Ground and Physical Plant Improvement Unit' ? 'selected' : '' %>>Ground and Physical Plant Improvement Unit (GPU)</option>
                    <option value="Health Unit" <%= selectedOffice === 'Health Unit' ? 'selected' : '' %>>Health Unit (HEU)</option>
                    <option value="Motorpool and Agri-Machinery Unit" <%= selectedOffice === 'Motorpool and Agri-Machinery Unit' ? 'selected' : '' %>>Motorpool and Agri-Machinery Unit (MAU)</option>
                </optgroup>
                <optgroup label="Research, Innovation, Extension and Training Cluster">
                    <option value="Office of the Vice President for Research, Innovation, Extension and Training" <%= selectedOffice === 'Office of the Vice President for Research, Innovation, Extension and Training' ? 'selected' : '' %>>Office of the VP for Research, Innovation, Extension and Training (VRE)</option>
                    <option value="Office of Extension and Training" <%= selectedOffice === 'Office of Extension and Training' ? 'selected' : '' %>>Office of Extension and Training (OET)</option>
                    <option value="Community Radio Station" <%= selectedOffice === 'Community Radio Station' ? 'selected' : '' %>>Community Radio Station (CRS)</option>
                    <option value="Satellite Cattle Breeding Center" <%= selectedOffice === 'Satellite Cattle Breeding Center' ? 'selected' : '' %>>Satellite Cattle Breeding Center (SCC)</option>
                    <option value="Technical Vocational Education and Training Center" <%= selectedOffice === 'Technical Vocational Education and Training Center' ? 'selected' : '' %>>Technical Vocational Education and Training Center (TVC)</option>
                    <option value="Office of Innovation" <%= selectedOffice === 'Office of Innovation' ? 'selected' : '' %>>Office of Innovation (OOI)</option>
                    <option value="Intellectual Property and Technology Business Management Unit" <%= selectedOffice === 'Intellectual Property and Technology Business Management Unit' ? 'selected' : '' %>>Intellectual Property and Technology Business Management Unit (ITU)</option>
                    <option value="Technology Business Incubation Unit" <%= selectedOffice === 'Technology Business Incubation Unit' ? 'selected' : '' %>>Technology Business Incubation Unit (TBU)</option>
                    <option value="Office of Research and Development" <%= selectedOffice === 'Office of Research and Development' ? 'selected' : '' %>>Office of Research and Development (ORD)</option>
                    <option value="Alternative Low-Input Agricultural System RDE Center" <%= selectedOffice === 'Alternative Low-Input Agricultural System RDE Center' ? 'selected' : '' %>>Alternative Low-Input Agricultural System RDE Center (ARC)</option>
                    <option value="Bamboo & Rattan RDE Center" <%= selectedOffice === 'Bamboo & Rattan RDE Center' ? 'selected' : '' %>>Bamboo & Rattan RDE Center (BRC)</option>
                    <option value="Tamarind RDE Center" <%= selectedOffice === 'Tamarind RDE Center' ? 'selected' : '' %>>Tamarind RDE Center (TRC)</option>
                </optgroup>
                <optgroup label="Planning and Resource Generation Cluster">
                    <option value="Office of the Vice President for Planning and Resource Generation" <%= selectedOffice === 'Office of the Vice President for Planning and Resource Generation' ? 'selected' : '' %>>Office of the VP for Planning and Resource Generation (VPR)</option>
                    <option value="Office of Business Affairs" <%= selectedOffice === 'Office of Business Affairs' ? 'selected' : '' %>>Office of Business Affairs (OBA)</option>
                    <option value="Agribusiness Unit" <%= selectedOffice === 'Agribusiness Unit' ? 'selected' : '' %>>Agribusiness Unit (ABU)</option>
                    <option value="Non-Agribusiness Unit" <%= selectedOffice === 'Non-Agribusiness Unit' ? 'selected' : '' %>>Non-Agribusiness Unit (NAU)</option>
                    <option value="Marketing Unit" <%= selectedOffice === 'Marketing Unit' ? 'selected' : '' %>>Marketing Unit (MRU)</option>
                    <option value="Office of Planning, Project Development and Monitoring" <%= selectedOffice === 'Office of Planning, Project Development and Monitoring' ? 'selected' : '' %>>Office of Planning, Project Development and Monitoring (OPP)</option>
                    <option value="Disaster Risk Reduction and Management Unit" <%= selectedOffice === 'Disaster Risk Reduction and Management Unit' ? 'selected' : '' %>>Disaster Risk Reduction and Management Unit (DRU)</option>
                    <option value="Land and Agroecological Resource Management Unit" <%= selectedOffice === 'Land and Agroecological Resource Management Unit' ? 'selected' : '' %>>Land and Agroecological Resource Management Unit (LAU)</option>
                    <option value="Management Information System Unit" <%= selectedOffice === 'Management Information System Unit' ? 'selected' : '' %>>Management Information System Unit (MIU)</option>
                    <option value="Planning Unit" <%= selectedOffice === 'Planning Unit' ? 'selected' : '' %>>Planning Unit (PLU)</option>
                    <option value="Project Development, Management and Monitoring Unit" <%= selectedOffice === 'Project Development, Management and Monitoring Unit' ? 'selected' : '' %>>Project Development, Management and Monitoring Unit (PMU)</option>
                </optgroup>
            </select>
            <div class="filter-date-group">
                <i class="fas fa-calendar-alt date-icon"></i>

                <input type="date" id="dateFrom" class="filter-date" value="<%= typeof dateFrom !== 'undefined' ? dateFrom : '' %>">
                <span class="date-sep">to</span>
                <input type="date" id="dateTo" class="filter-date" value="<%= typeof dateTo !== 'undefined' ? dateTo : '' %>">

            </div>
            <button class="btn-apply" onclick="applyFilters()"><i class="fas fa-check"></i> Apply</button>
            <button class="btn-report" onclick="generateReport()" title="Generate detailed printable report"><i class="fas fa-file-alt"></i> Report</button>
            <span class="filter-count">
                <i class="fas fa-info-circle"></i>
                <strong><%= feedbacks.length %></strong> / <strong><%= allFeedbacks.length %></strong>
            </span>
        </div>

        <% 
    
        const safeSelectedOffice = typeof selectedOffice !== 'undefined' ? selectedOffice : 'all';
        const safeDateFrom = typeof dateFrom !== 'undefined' ? dateFrom : '';
        const safeDateTo = typeof dateTo !== 'undefined' ? dateTo : '';
        %>

        <% if (safeSelectedOffice !== 'all' || safeDateFrom || safeDateTo) { %>
        <div class="active-filter-banner">
            <i class="fas fa-filter-circle-xmark banner-icon" style="font-size:1rem;"></i>
            <div>
                <% if (safeSelectedOffice !== 'all') { %><span class="banner-info"><%= safeSelectedOffice %></span><% } %>
                <% if (safeDateFrom) { %><span class="banner-sub">From: <%= safeDateFrom %></span><% } %>
                <% if (safeDateTo) { %><span class="banner-sub">To: <%= safeDateTo %></span><% } %>
                <% if (safeSelectedOffice === 'all' && !safeDateFrom && !safeDateTo) { %>
                <span class="banner-info">All Offices</span>
                <% } %>
            </div>
            <a href="/admin/dashboard" class="clear-filter"><i class="fas fa-times"></i> Clear All Filters</a>
        </div>
        <% } %>

        <% if (selectedOffice !== 'all') { %>
            <!-- Department Profile & Comparative Insights -->
            <div class="ai-section" style="margin-top: 1rem; margin-bottom: 2.2rem;">
                <div class="ai-card" style="border-left: 4px solid var(--psau-green); background: linear-gradient(135deg, #ffffff 0%, #f7fbf7 100%);">
                    <div class="ai-header" style="border-bottom: 1px solid var(--border-color); padding-bottom: 0.75rem; margin-bottom: 1rem;">
                        <h3 style="font-size: 1.15rem; font-weight: 800;"><i class="fas fa-building" style="color: var(--psau-green); margin-right: 0.35rem;"></i> <%= selectedOffice %> — Office Profile Summary</h3>
                        <span class="badge positive" style="padding: 0.35rem 0.85rem; background: rgba(27,94,32,0.12); color: var(--psau-green); border: 1px solid rgba(27,94,32,0.2);"><i class="fas fa-users"></i> <%= feedbacks.length %> Respondents</span>
                    </div>
                    
                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; margin-top: 0.75rem;">
                        <div>
                            <h4 style="font-size: 0.82rem; text-transform: uppercase; color: var(--psau-green); margin-bottom: 0.75rem; display: flex; align-items: center; gap: 0.4rem; font-weight: 800; letter-spacing: 0.5px;"><i class="fas fa-chevron-up"></i> Top Performance Strengths</h4>
                            <% 
                                const sqdLabels = [
                                    'SQD0 - General Satisfaction',
                                    'SQD1 - Speed & Waiting Time',
                                    'SQD2 - Requirements Compliance',
                                    'SQD3 - Ease of Steps & Payment',
                                    'SQD4 - Location & Access',
                                    'SQD5 - Fair & Reasonable Fees',
                                    'SQD6 - Equality & Fair Treatment',
                                    'SQD7 - Staff Courtesy & Support',
                                    'SQD8 - Transaction Outcome'
                                ];
                                let sqdWithScores = chartData.sqdAverages.map((score, idx) => ({ label: sqdLabels[idx], score }));
                                let strengths = [...sqdWithScores].sort((a,b) => b.score - a.score).filter(item => item.score > 0).slice(0, 2);
                                let weaknesses = [...sqdWithScores].sort((a,b) => a.score - b.score).filter(item => item.score > 0).slice(0, 2);
                            %>
                            <% if (strengths.length > 0) { %>
                                <ul style="list-style: none; padding: 0; margin: 0;">
                                    <% strengths.forEach(item => { %>
                                        <li style="margin-bottom: 0.6rem; font-size: 0.85rem; display: flex; align-items: center; justify-content: space-between; background: rgba(255,255,255,0.7); padding: 0.5rem 0.75rem; border-radius: 6px; border: 1px solid var(--border-color);">
                                            <span style="color: var(--text-secondary); font-weight: 500;"><%= item.label %></span>
                                            <strong style="color: #2e7d32; font-weight: 800; background: rgba(76,175,80,0.1); padding: 0.15rem 0.45rem; border-radius: 4px;"><%= item.score.toFixed(2) %>/5.00</strong>
                                        </li>
                                    <% }) %>
                                </ul>
                            <% } else { %>
                                <p style="font-size:0.8rem; color:#9ea4b8; font-style:italic;">No rating data available for analysis.</p>
                            <% } %>
                        </div>
                        
                        <div>
                            <h4 style="font-size: 0.82rem; text-transform: uppercase; color: #d32f2f; margin-bottom: 0.75rem; display: flex; align-items: center; gap: 0.4rem; font-weight: 800; letter-spacing: 0.5px;"><i class="fas fa-chevron-down"></i> Areas Requesting Improvement</h4>
                            <% if (weaknesses.length > 0) { %>
                                <ul style="list-style: none; padding: 0; margin: 0;">
                                    <% weaknesses.forEach(item => { %>
                                        <li style="margin-bottom: 0.6rem; font-size: 0.85rem; display: flex; align-items: center; justify-content: space-between; background: rgba(255,255,255,0.7); padding: 0.5rem 0.75rem; border-radius: 6px; border: 1px solid var(--border-color);">
                                            <span style="color: var(--text-secondary); font-weight: 500;"><%= item.label %></span>
                                            <strong style="color: #c62828; font-weight: 800; background: rgba(244,67,54,0.08); padding: 0.15rem 0.45rem; border-radius: 4px;"><%= item.score.toFixed(2) %>/5.00</strong>
                                        </li>
                                    <% }) %>
                                </ul>
                            <% } else { %>
                                <p style="font-size:0.8rem; color:#9ea4b8; font-style:italic;">No rating data available for analysis.</p>
                            <% } %>
                        </div>
                        
                        <div style="border-left: 1px solid var(--border-color); padding-left: 1.5rem;">
                            <h4 style="font-size: 0.82rem; text-transform: uppercase; color: var(--text-primary); margin-bottom: 0.75rem; display: flex; align-items: center; gap: 0.4rem; font-weight: 800; letter-spacing: 0.5px;"><i class="fas fa-project-diagram" style="color: #42a5f5;"></i> Comparative Cluster Rank</h4>
                            <% 
                                const deptCluster = clusteredDepartments.find(d => d.name === selectedOffice);
                            %>
                            <% if (deptCluster) { %>
                                <div style="margin-bottom: 0.6rem; font-size: 0.85rem;">
                                    K-Means Status: 
                                    <% if (deptCluster.cluster.includes('Outstanding') || deptCluster.cluster.includes('Excellent')) { %>
                                        <span class="badge positive" style="font-size: 0.7rem; padding: 0.2rem 0.5rem;"><%= deptCluster.cluster %></span>
                                    <% } else if (deptCluster.cluster.includes('Needs Attention') || deptCluster.cluster.includes('Improvement')) { %>
                                        <span class="badge negative" style="font-size: 0.7rem; padding: 0.2rem 0.5rem;"><%= deptCluster.cluster %></span>
                                    <% } else { %>
                                        <span class="badge mixed" style="font-size: 0.7rem; padding: 0.2rem 0.5rem;"><%= deptCluster.cluster %></span>
                                    <% } %>
                                </div>
                                <div style="font-size: 0.8rem; color: var(--text-secondary); line-height: 1.5; background: rgba(0,0,0,0.02); padding: 0.5rem 0.75rem; border-radius: 6px; border: 1px dashed var(--border-color);">
                                    Comparative standing: <strong>Rank #<%= clusteredDepartments.findIndex(d => d.name === selectedOffice) + 1 %></strong> out of <strong><%= clusteredDepartments.length %></strong> rated offices university-wide.
                                </div>
                            <% } else { %>
                                <p style="font-size:0.8rem; color:#9ea4b8; font-style:italic;">No cluster position assigned yet.</p>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        <% } %>

        <!-- Stats -->
        <div class="stats-grid">
            <div class="stat-card green">
                <div class="stat-icon"><i class="fas fa-clipboard-list"></i></div>
                <div class="stat-value"><%= stats.totalResponses %></div>
                <div class="stat-label">Total Responses</div>
            </div>
            <div class="stat-card blue">
                <div class="stat-icon"><i class="fas fa-star"></i></div>
                <div class="stat-value"><%= stats.avgSQD %></div>
                <div class="stat-label">Average SQD Rating</div>
            </div>
            <div class="stat-card gold">
                <div class="stat-icon"><i class="fas fa-smile"></i></div>
                <div class="stat-value"><%= stats.positivePct %>%</div>
                <div class="stat-label">Positive Sentiment</div>
            </div>
            <div class="stat-card pink">
                <div class="stat-icon"><i class="fas fa-comment-dots"></i></div>
                <div class="stat-value"><%= stats.totalSuggestions %></div>
