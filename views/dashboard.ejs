            {name:"Satellite Cattle Breeding Center",code:"SCC"},{name:"Technical Vocational Education and Training Center",code:"TVC"},
            {name:"Office of Innovation",code:"OOI"},{name:"Intellectual Property and Technology Business Management Unit",code:"ITU"},
